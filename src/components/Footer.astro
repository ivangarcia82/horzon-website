<footer class="site-footer" id="contacto-footer">
  <div class="footer-grid">
    <div class="footer-brand">
      <div class="footer-logo">HORZON</div>
    </div>

    <div class="footer-col">
      <h4>Marcas</h4>
      <ul>
        <li><a href="#">ALTIRO</a></li>
        <li><a href="#">FORTEM</a></li>
        <li><a href="#">REACTOR</a></li>
        <li><a href="#">FACTROL</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h4>Contacto</h4>
      <ul>
        <li>+52 (999) 358 94 93</li>
        <li>contacto@horzon.com.mx</li>
        <li>Mérida, México.</li>
      </ul>
      <div class="social-icons">
        <a href="#" class="social-icon" aria-label="Facebook">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"
            ><path
              d="M13 10h3l-1 4h-2v7h-3v-7H8v-4h2V8c0-2.2 1.8-4 4-4h2v4h-2c-.6 0-1 .4-1 1v1z"
            ></path></svg
          >
        </a>
        <a href="#" class="social-icon" aria-label="Instagram">
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <rect x="3" y="3" width="18" height="18" rx="4"></rect>
            <circle cx="12" cy="12" r="4"></circle>
            <circle cx="17" cy="7" r="0.8" fill="currentColor"></circle>
          </svg>
        </a>
        <a href="#" class="social-icon" aria-label="WhatsApp">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"
            ><path
              d="M20 4a10 10 0 0 0-16 12L3 21l5-1a10 10 0 0 0 12-16zm-5 12c-.3 0-2-.7-3.5-2.1-1.4-1.4-2.4-3.2-2.4-3.4 0-.3.7-.9 1-1 .2-.1.4 0 .5.1l.7 1.2c.1.2.1.4-.1.5l-.3.4c.2.3.7 1 1.3 1.5.6.6 1.2.9 1.5 1l.4-.3c.1-.2.3-.2.5-.1l1.2.7c.2.1.2.3.1.5-.1.3-.6 1-1 1z"
            ></path></svg
          >
        </a>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    Copyright 2025 Horzon Núcleo Empresarial by Banana People.
  </div>
</footer>

<style>
  .site-footer {
    background: #fff;
    padding: 80px 80px 20px;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr 1fr;
    gap: 80px;
    align-items: start;
    max-width: 1200px;
    margin: 0 auto;
    padding-bottom: 40px;
  }

  .footer-logo {
    font-size: 32px;
    font-weight: 500;
    letter-spacing: 0.35em;
    color: #333;
    transform: scaleX(1.1);
    transform-origin: left;
    display: inline-block;
    background: linear-gradient(
      180deg,
      #555 0%,
      #555 45%,
      #fff 45%,
      #fff 55%,
      #555 55%,
      #555 100%
    );
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .footer-col {
    position: relative;
    padding-left: 30px;
  }

  .footer-col::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 1px;
    background: #cfcfcf;
  }

  .footer-col h4 {
    font-size: 15px;
    font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 22px;
  }

  .footer-col ul {
    list-style: none;
  }

  .footer-col li {
    margin-bottom: 12px;
    font-size: 14px;
    color: #3a3a3a;
  }

  .footer-col a {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-col a:hover {
    color: #000;
  }

  .social-icons {
    display: flex;
    gap: 10px;
    margin-top: 20px;
  }

  .social-icon {
    width: 34px;
    height: 34px;
    background: #888;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    text-decoration: none;
    font-size: 14px;
    transition: background 0.2s;
  }

  .social-icon:hover {
    background: #555;
  }

  .footer-bottom {
    border-top: 1px solid var(--footer-border);
    padding-top: 20px;
    font-size: 12px;
    color: #4a4a4a;
    max-width: 1200px;
    margin: 0 auto;
  }

  @media (max-width: 960px) {
    .site-footer {
      padding: 60px 24px 20px;
    }
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .footer-col {
      padding-left: 0;
    }
    .footer-col::before {
      display: none;
    }
  }
</style>
