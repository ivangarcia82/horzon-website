---
interface Props {
  variant?: 'transparent' | 'gray';
  activePage?: 'home' | 'contacto';
}

const { variant = 'transparent', activePage = 'home' } = Astro.props;

const homeHref = activePage === 'home' ? '#' : '/';
const inicioHref = activePage === 'home' ? '#inicio' : '/#inicio';
const nosotrosHref = activePage === 'home' ? '#nosotros' : '/#nosotros';
const marcasHref = activePage === 'home' ? '#marcas' : '/#marcas';
const contactoHref = activePage === 'contacto' ? '#contacto' : '/contacto';
const serviciosHref = '#servicios';
---

<header class:list={['site-header', `variant-${variant}`]}>
  <a href={homeHref} class="logo" aria-label="HORZON">
    <img src="/Positivo-.png" alt="HORZON" class="logo-img" />
  </a>
  <nav class="nav-links">
    <a href={inicioHref}>Inicio</a>
    <a href={nosotrosHref}>Nosotros</a>
    <a href={marcasHref}>Marcas</a>
    <a href={contactoHref}>Contacto</a>
    <a href={serviciosHref}>Servicios</a>
  </nav>
</header>

<style>
  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .site-header.variant-transparent {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 10;
    padding: 36px 80px;
  }

  .site-header.variant-gray {
    position: relative;
    background: var(--gray-section);
    padding: 30px 80px;
  }

  .logo {
    text-decoration: none;
    display: flex;
    align-items: center;
  }

  .logo-img {
    height: 26px;
    width: auto;
    filter: brightness(0) invert(1);
    display: block;
  }

  .site-header.variant-gray .logo-img {
    height: 24px;
  }

  .nav-links {
    display: flex;
    gap: 38px;
    align-items: center;
  }

  .nav-links a {
    color: #fff;
    text-decoration: none;
    font-size: 15px;
    font-weight: 400;
    letter-spacing: 0.2px;
    transition: opacity 0.2s;
  }

  .nav-links a:hover {
    opacity: 0.7;
  }

  .nav-separator {
    color: #fff;
    opacity: 0.5;
  }

  @media (max-width: 960px) {
    .site-header.variant-transparent {
      padding: 24px 24px;
    }
    .site-header.variant-gray {
      padding: 20px 24px;
    }
    .nav-links {
      gap: 18px;
    }
    .nav-links a {
      font-size: 13px;
    }
    .site-header.variant-gray .nav-links {
      gap: 14px;
    }
    .site-header.variant-gray .nav-links a {
      font-size: 12px;
    }
    .logo-img {
      height: 22px;
    }
    .site-header.variant-gray .logo-img {
      height: 20px;
    }
  }
</style>
