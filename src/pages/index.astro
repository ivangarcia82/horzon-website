---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="HORZON — Núcleo Empresarial">
  <Header variant="transparent" activePage="home" />

  <!-- ============ HERO ============ -->
  <section class="hero" id="inicio">
    <div class="hero-bg"></div>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h1 class="hero-title">
        <span class="line">Cada marca, una oportunidad.</span>
        <span class="line">Cada oportunidad, un horizonte.</span>
      </h1>
    </div>
  </section>

  <!-- ============ ABOUT ============ -->
  <section class="about" id="nosotros">
    <div class="about-text">
      <p>
        Somos un núcleo empresarial fundado en 1980, con más de cuatro décadas
        de experiencia dedicadas a desarrollar soluciones que impulsan distintos
        sectores e industrias a nivel nacional.
      </p>
      <p>
        Desde Yucatán, conectamos conocimiento, estrategia y visión para
        transformar cada proyecto en una oportunidad de crecimiento.
      </p>
      <a href="#" class="btn-light">CONOCE MÁS</a>
    </div>
    <div class="about-image" role="img" aria-label="Equipo Horzon"></div>
  </section>

  <!-- ============ BRANDS ============ -->
  <section class="brands" id="marcas">
    <h2 class="brands-heading">
      Conoce nuestras marcas, cada una dedicada a un área específica.
    </h2>
    <a href="#" class="brands-cta">CONOCE NUESTRAS MARCAS</a>

    <div class="brands-carousel">
      <div class="brand-cards">
        <a href="#" class="brand-card red">
          <span class="brand-arrow">
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="M7 17L17 7M17 7H8M17 7V16"></path>
            </svg>
          </span>
          <img
            src="/fortemlogo.png"
            alt="FORTEM — Blindaje Integral"
            class="brand-logo"
          />
        </a>

        <a href="#" class="brand-card orange">
          <span class="brand-arrow">
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="M7 17L17 7M17 7H8M17 7V16"></path>
            </svg>
          </span>
          <img
            src="/altirologo.jpg"
            alt="ALTIRO — Automotriz Diesel & Carrocerías"
            class="brand-logo brand-logo-altiro"
          />
        </a>

        <a href="#" class="brand-card green">
          <span class="brand-arrow">
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="M7 17L17 7M17 7H8M17 7V16"></path>
            </svg>
          </span>
          <img
            src="/reactorlogo.png"
            alt="REACTOR — Power Connect"
            class="brand-logo"
          />
        </a>
      </div>

      <div class="carousel-dots">
        <button class="dot" data-idx="0" aria-label="Slide 1"></button>
        <button class="dot active" data-idx="1" aria-label="Slide 2"></button>
        <button class="dot" data-idx="2" aria-label="Slide 3"></button>
      </div>
    </div>
  </section>

  <!-- ============ QUOTE ============ -->
  <section class="quote-section">
    <div class="quote-bg"></div>
    <div class="quote-card">
      <img src="/Gris-.png" alt="" aria-hidden="true" class="quote-mark" />
      <p class="quote-text">
        En Horzon creemos en<br />
        horizontes sin límites
      </p>
      <div class="quote-decor"></div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<script>
  const dots = document.querySelectorAll<HTMLButtonElement>('.dot');
  dots.forEach((dot) => {
    dot.addEventListener('click', () => {
      dots.forEach((d) => d.classList.remove('active'));
      dot.classList.add('active');
    });
  });
</script>

<style>
  /* ============ HERO ============ */
  .hero {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    display: flex;
    align-items: center;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background-image: url('https://images.unsplash.com/photo-1504328345606-18bbc8c9d7d1?w=1920&q=80');
    background-size: cover;
    background-position: center;
    filter: grayscale(1) brightness(0.55);
    z-index: 0;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.35) 0%,
      rgba(0, 0, 0, 0.15) 40%,
      rgba(0, 0, 0, 0.35) 100%
    );
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    padding: 0 80px;
    max-width: 900px;
  }

  .hero-title {
    color: #fff;
    font-size: 28px;
    font-weight: 400;
    letter-spacing: 0.05em;
    line-height: 1.4;
    text-transform: uppercase;
  }

  .hero-title .line {
    display: block;
  }

  /* ============ ABOUT ============ */
  .about {
    background: var(--gray-section);
    padding: 120px 80px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 100px;
    align-items: center;
    min-height: 600px;
  }

  .about-text {
    color: #fff;
    max-width: 480px;
    justify-self: end;
    font-size: 15px;
    line-height: 1.65;
    text-align: justify;
  }

  .about-text p {
    margin-bottom: 22px;
  }

  .btn-light {
    display: inline-block;
    margin-top: 12px;
    padding: 14px 32px;
    background: #f5f1e8;
    color: #1a1a1a;
    border: none;
    border-radius: 999px;
    text-decoration: none;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.15em;
    cursor: pointer;
    transition:
      transform 0.2s,
      background 0.2s;
    font-family: inherit;
  }

  .btn-light:hover {
    transform: translateY(-1px);
    background: #fff;
  }

  .about-image {
    width: 100%;
    max-width: 520px;
    aspect-ratio: 4 / 3;
    background-image: url('https://images.unsplash.com/photo-1521737604893-d14cc237f11d?w=1200&q=80');
    background-size: cover;
    background-position: center;
    filter: grayscale(1);
  }

  /* ============ BRANDS ============ */
  .brands {
    background: #fff;
    padding: 120px 80px 140px;
    text-align: center;
  }

  .brands-heading {
    font-size: 22px;
    font-weight: 400;
    color: var(--fg);
    margin-bottom: 20px;
    letter-spacing: 0.01em;
  }

  .brands-cta {
    font-size: 12px;
    letter-spacing: 0.2em;
    font-weight: 500;
    color: var(--fg);
    text-decoration: none;
    display: inline-block;
    margin-bottom: 70px;
    padding-bottom: 4px;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s;
  }

  .brands-cta:hover {
    border-bottom-color: var(--fg);
  }

  .brands-carousel {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
  }

  .brand-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    padding: 0 20px;
  }

  .brand-card {
    aspect-ratio: 3 / 4;
    border-radius: 28px;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: transform 0.3s ease;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  }

  .brand-card:hover {
    transform: translateY(-6px);
  }

  .brand-card.red {
    background: var(--card-red);
  }
  .brand-card.orange {
    background: var(--card-orange);
  }
  .brand-card.green {
    background: var(--card-green);
  }

  .brand-arrow {
    position: absolute;
    top: 20px;
    right: 20px;
    width: 40px;
    height: 40px;
    background: #fff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #1a1a1a;
    font-size: 18px;
  }

  .brand-logo {
    width: 75%;
    max-width: 220px;
    height: auto;
    object-fit: contain;
    padding: 20px;
  }

  /* ALTIRO logo is a JPG with a white background — blend it out */
  .brand-logo-altiro {
    mix-blend-mode: multiply;
    width: 80%;
    max-width: 240px;
  }

  .carousel-dots {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-top: 50px;
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #d0d0d0;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background 0.2s;
  }

  .dot.active {
    background: #888;
  }

  /* ============ QUOTE ============ */
  .quote-section {
    position: relative;
    min-height: 620px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 80px 40px;
  }

  .quote-bg {
    position: absolute;
    inset: 0;
    background-image: url('https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?w=1920&q=80');
    background-size: cover;
    background-position: center;
    filter: grayscale(1) brightness(0.55);
    z-index: 0;
  }

  .quote-card {
    position: relative;
    z-index: 2;
    background: #fff;
    padding: 80px 60px 60px;
    width: min(820px, 90%);
    text-align: center;
    border-bottom: 0;
  }

  .quote-mark {
    display: inline-block;
    width: 72px;
    height: auto;
    object-fit: contain;
    margin-bottom: 36px;
  }

  .quote-text {
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 0.25em;
    line-height: 1.7;
    color: #5a5a5a;
    text-transform: uppercase;
  }

  .quote-decor {
    position: absolute;
    left: 0;
    right: 0;
    bottom: -0px;
    height: 36px;
    background: repeating-linear-gradient(
      to bottom,
      #fff 0px,
      #fff 4px,
      #b5b5b5 4px,
      #b5b5b5 5px
    );
    transform: translateY(100%);
  }

  /* ============ RESPONSIVE ============ */
  @media (max-width: 960px) {
    .hero-content {
      padding: 0 24px;
    }
    .hero-title {
      font-size: 18px;
    }
    .about {
      grid-template-columns: 1fr;
      padding: 80px 24px;
      gap: 40px;
    }
    .about-text {
      justify-self: start;
    }
    .about-image {
      max-width: 100%;
    }
    .brands {
      padding: 80px 24px;
    }
    .brand-cards {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .quote-card {
      padding: 50px 30px;
    }
  }
</style>
